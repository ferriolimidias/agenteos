# ==========================================
# PostgreSQL (compose + backend)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_super_secreta
POSTGRES_DB=agent_os

# ==========================================
# Redis (opcional no .env — o docker-compose injeta REDIS_URL no backend)
# ==========================================
# REDIS_URL=redis://redis:6379/0

# ==========================================
# Deploy VPS (Nginx + Certbot / scripts)
# ==========================================
DOMAIN=app.seudominio.com
EMAIL=admin@seudominio.com

# ==========================================
# Evolution API (rede interna Docker)
# EVOLUTION_API_TOKEN: autenticação global na Evolution (header apikey nas rotas administrativas)
# EVOLUTION_API_URL: URL que o backend usa para falar com o container evolution
# ==========================================
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_TOKEN=defina_um_token_forte_em_producao

# Chaves OpenAI por tenant ficam no painel (credenciais da empresa / config global).
# DATABASE_URL para o backend é montado pelo docker-compose a partir do POSTGRES_* acima.
