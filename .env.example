# ==========================================
# Configurações do Banco de Dados (PostgreSQL)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_super_secreta
POSTGRES_DB=agent_os

# A URL do banco usada pelo FastAPI no docker-compose (resolve para o container 'db')
DATABASE_URL=postgresql+asyncpg://postgres:sua_senha_super_secreta@db:5432/agent_os

# ==========================================
# Cache e Mensageria (Redis)
# ==========================================
REDIS_URL=redis://redis:6379/0

# ==========================================
# Deploy VPS (Nginx + Certbot)
# ==========================================
DOMAIN=app.seudominio.com
EMAIL=admin@seudominio.com

# ==========================================
# Chaves de API de IA
# ==========================================
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# Evolution API (WhatsApp) — URL pública usada pela Evolution (webhook, links, etc.)
# ==========================================
SERVER_URL=https://evolution.ferriolimidias.com.br

# Token global da Evolution (AUTHENTICATION_API_KEY); use um valor forte em produção
EVOLUTION_API_TOKEN=31DBC9312D34F1477F2DB8B8C9FE3

# URL interna Docker para o backend AgenteOS falar com a Evolution (rede agenteos_network)
EVOLUTION_API_URL=http://evolution:8080

# ==========================================
# Evolution API — armazenamento S3 (mídias)
# ==========================================
EVOLUTION_S3_ACCESS_KEY=8wsqHxfbDBtmcBKbJvZN
EVOLUTION_S3_SECRET_KEY=aMKBEJg7xUzr0NDERXKCCTJ6doqrXErrGC5XbmA6
EVOLUTION_S3_BUCKET=evolution
EVOLUTION_S3_PORT=443
EVOLUTION_S3_ENDPOINT=s3.ferriolimidias.com.br
EVOLUTION_S3_USE_SSL=true
EVOLUTION_S3_REGION=eu-south

# Webhook Local (Exemplo de URL caso o webhook da Evolution precise mirar para o backend web)
# WEBHOOK_URL_BASE=https://api.empresa.com/api/webhook
